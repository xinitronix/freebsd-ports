#!/bin/sh
mkdir $HOME/.config/cstrike
cd    $HOME/.config/cstrike
ln -s /usr/local/share/cstrike/bin bin
ln -s /usr/local/share/cstrike/hl2_launcher hl2_launcher
ln -s "/media/Steam/steamapps/common/Counter-Strike Source/depots/241/17399420/cstrike" cstrike
ln -s "/media/Steam/steamapps/common/Counter-Strike Source/depots/241/17399420/hl2" hl2
./hl2_launcher -game cstrike  "$@"